@bg = PatchStyle(TexturePath: "bg.png");

Group #MainGroup {
    Anchor: (Top: 100, Left: 200, Width: 600, Height: 400);
    Background: @bg;

    Label #Titre {
        Text: "EXPERIENCE MOD";
        Anchor: (Top: 15, Left: 200);
    }

    Label #SousTitre {
        Text: "Liste des parties";
        Anchor: (Top: 45, Left: 220);
    }

    // ── Partie 1 ──────────────────────────────────────
    Group #Partie1 {
        Anchor: (Top: 80, Left: 20, Width: 560, Height: 70);
        Background: @bg;

        Label #NomPartie1 {
            Text: "Partie 1";
            Anchor: (Top: 25, Left: 15);
        }

        Label #Joueurs1 {
            Text: "0/10";
            Anchor: (Top: 25, Left: 200);
        }

        Label #Statut1 {
            Text: "En attente";
            Anchor: (Top: 25, Left: 310);
        }

        Label #Rejoindre1 {
            Text: "[Rejoindre]";
            Anchor: (Top: 25, Left: 440);
        }
    }

    // ── Partie 2 ──────────────────────────────────────
    Group #Partie2 {
        Anchor: (Top: 160, Left: 20, Width: 560, Height: 70);
        Background: @bg;

        Label #NomPartie2 {
            Text: "Partie 2";
            Anchor: (Top: 25, Left: 15);
        }

        Label #Joueurs2 {
            Text: "0/10";
            Anchor: (Top: 25, Left: 200);
        }

        Label #Statut2 {
            Text: "En attente";
            Anchor: (Top: 25, Left: 310);
        }

        Label #Rejoindre2 {
            Text: "[Rejoindre]";
            Anchor: (Top: 25, Left: 440);
        }
    }

    // ── Partie 3 ──────────────────────────────────────
    Group #Partie3 {
        Anchor: (Top: 240, Left: 20, Width: 560, Height: 70);
        Background: @bg;

        Label #NomPartie3 {
            Text: "Partie 3";
            Anchor: (Top: 25, Left: 15);
        }

        Label #Joueurs3 {
            Text: "0/10";
            Anchor: (Top: 25, Left: 200);
        }

        Label #Statut3 {
            Text: "En attente";
            Anchor: (Top: 25, Left: 310);
        }

        Label #Rejoindre3 {
            Text: "[Rejoindre]";
            Anchor: (Top: 25, Left: 440);
        }
    }

    Label #Fermer {
        Text: "[Fermer]";
        Anchor: (Top: 340, Left: 260);
    }
}
