$Common = "Common.ui";

@bg = PatchStyle(TexturePath: "bg.png");

Group {
    LayoutMode: Center;

    Group #MainPanel {
        Background: @bg;
        Anchor: (Width: 700, Height: 450);
        LayoutMode: Top;

        Label #Titre {
            Style: (FontSize: 32, Alignment: Center);
            Anchor: (Top: 20);
            Text: "EXPERIENCE MOD";
            Padding: (Full: 10);
        }

        Label #SousTitre {
            Style: (FontSize: 18, Alignment: Center);
            Anchor: (Top: 5);
            Text: "Liste des parties";
            Padding: (Full: 5);
        }

        // ── Partie 1 ──────────────────────────────
        Group #Partie1 {
            Background: @bg;
            Anchor: (Top: 15, Width: 650, Height: 70);
            LayoutMode: Left;

            Label #NomPartie1 {
                Style: (FontSize: 16);
                Anchor: (Width: 200, Height: 70);
                Text: "Partie 1";
                Padding: (Left: 20, Top: 25);
            }

            Label #Joueurs1 {
                Style: (FontSize: 16);
                Anchor: (Width: 100, Height: 70);
                Text: "0/10";
                Padding: (Top: 25);
            }

            Label #Statut1 {
                Style: (FontSize: 16);
                Anchor: (Width: 180, Height: 70);
                Text: "En attente";
                Padding: (Top: 25);
            }

            Label #Rejoindre1 {
                Style: (FontSize: 16);
                Anchor: (Width: 150, Height: 70);
                Text: "[Rejoindre]";
                Padding: (Top: 25);
            }
        }

        // ── Partie 2 ──────────────────────────────
        Group #Partie2 {
            Background: @bg;
            Anchor: (Top: 10, Width: 650, Height: 70);
            LayoutMode: Left;

            Label #NomPartie2 {
                Style: (FontSize: 16);
                Anchor: (Width: 200, Height: 70);
                Text: "Partie 2";
                Padding: (Left: 20, Top: 25);
            }

            Label #Joueurs2 {
                Style: (FontSize: 16);
                Anchor: (Width: 100, Height: 70);
                Text: "0/10";
                Padding: (Top: 25);
            }

            Label #Statut2 {
                Style: (FontSize: 16);
                Anchor: (Width: 180, Height: 70);
                Text: "En cours";
                Padding: (Top: 25);
            }

            Label #Rejoindre2 {
                Style: (FontSize: 16);
                Anchor: (Width: 150, Height: 70);
                Text: "";
                Padding: (Top: 25);
            }
        }

        // ── Partie 3 ──────────────────────────────
        Group #Partie3 {
            Background: @bg;
            Anchor: (Top: 10, Width: 650, Height: 70);
            LayoutMode: Left;

            Label #NomPartie3 {
                Style: (FontSize: 16);
                Anchor: (Width: 200, Height: 70);
                Text: "Partie 3";
                Padding: (Left: 20, Top: 25);
            }

            Label #Joueurs3 {
                Style: (FontSize: 16);
                Anchor: (Width: 100, Height: 70);
                Text: "0/10";
                Padding: (Top: 25);
            }

            Label #Statut3 {
                Style: (FontSize: 16);
                Anchor: (Width: 180, Height: 70);
                Text: "En attente";
                Padding: (Top: 25);
            }

            Label #Rejoindre3 {
                Style: (FontSize: 16);
                Anchor: (Width: 150, Height: 70);
                Text: "[Rejoindre]";
                Padding: (Top: 25);
            }
        }
    }
}
